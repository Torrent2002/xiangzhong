# ===== AI 调用配置（OpenAI 兼容）=====
# 留空 OPENAI_API_KEY 即走"本地兜底模式"，demo 照样完整跑通、不报错。
# 配了 key 就接真实 LLM（显性意图解析 / 隐性偏好反推 / 照片识别）。

# 必填：API Key。留空 = 本地兜底模式。
OPENAI_API_KEY=

# OpenAI 兼容端点。不填则用 OpenAI 官方。
# 兼容厂商示例：
#   豆包(火山引擎)   https://ark.cn-beijing.volces.com/api/coding/v3  （doubao-seed-2.0-pro 多模态，文本+vision 已实测）
#   Qwen(通义千问)   https://dashscope.aliyuncs.com/compatible-mode/v1
#   DeepSeek         https://api.deepseek.com/v1   （纯文本，不支持图片）
#   GLM(智谱)        https://open.bigmodel.cn/api/paas/v4
#   OpenAI           （留空，默认）
OPENAI_BASE_URL=

# 模型名（按厂商填）：
#   doubao-seed-2.0-pro   （豆包多模态，文本+vision 都可用，已实测）
#   qwen-plus / qwen-turbo
#   deepseek-chat          （纯文本）
#   glm-4-flash
#   gpt-4o-mini
MODEL=gpt-4o-mini

# 多模态 vision 模型（用于「上传理想型照片」识别外貌特征）。
# 注意：deepseek-chat 不支持图片！要启用照片识别，VISION_MODEL 必须配成支持 vision 的模型：
#   doubao-seed-2.0-pro    （豆包多模态，已实测文本+vision 都可用）
#   qwen-vl-plus / qwen-vl-max   （阿里通义千问视觉）
#   glm-4v-flash / glm-4v        （智谱 GLM 视觉）
#   gpt-4o / gpt-4o-mini         （OpenAI，原生支持 vision）
# 留空则沿用上面的 MODEL；若 MODEL 不支持图片，照片识别会失败并自动降级（不报错）。
VISION_MODEL=

# 可选：embedding 模型。当前 match 已改为纯结构化打分（速度优先，不再逐候选调 LLM 语义分），
# 此项保留以备后续语义打分升级。多数兼容端点不支持 embedding。
EMBED_MODEL=text-embedding-3-small
