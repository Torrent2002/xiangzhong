# ===== AI 调用配置（OpenAI 兼容）=====
# 留空 OPENAI_API_KEY 即走"本地兜底模式"，demo 照样完整跑通、不报错。
# 配了 key 就接真实 LLM（显性解析 / 语义打分 / 隐性反推）。

# 必填：API Key。留空 = 本地兜底模式。
OPENAI_API_KEY=

# 可选：OpenAI 兼容端点。不填则用 OpenAI 官方。
# 兼容厂商示例：
#   Qwen(通义千问)   https://dashscope.aliyuncs.com/compatible-mode/v1
#   DeepSeek         https://api.deepseek.com/v1
#   Moonshot(月之暗面) https://api.moonshot.cn/v1
#   豆包(火山引擎)   https://ark.cn-beijing.volces.com/api/v3
#   GLM(智谱)        https://open.bigmodel.cn/api/paas/v4
#   OpenAI           （留空，默认）
OPENAI_BASE_URL=

# 模型名（按厂商填）：
#   qwen-plus / qwen-turbo
#   deepseek-chat
#   moonshot-v1-8k
#   doubao-pro-32k  （豆包需填接入点 id）
#   glm-4-flash
#   gpt-4o-mini
MODEL=gpt-4o-mini

# 可选：embedding 模型（用于显性语义打分；多数兼容端点不支持，失败时自动降级到结构化打分）
EMBED_MODEL=text-embedding-3-small
